# =============================================================
# Nexa Safety — Environment Variables
# =============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to version control — it contains secrets.
# =============================================================

# -------------------------------------------------------------
# DATABASE
# -------------------------------------------------------------
# PostgreSQL connection string.
#
# Local development (default):
#   DATABASE_URL=postgresql://user:password@localhost:5432/nexa_safety
#
# Railway (injected automatically by the Postgres plugin — no
# manual action needed when deploying to Railway):
#   DATABASE_URL=postgresql://postgres:<password>@<host>:<port>/railway
#
# The server reads this at startup. If it is missing the process
# will exit immediately with an error.
DATABASE_URL=postgresql://user:password@localhost:5432/nexa_safety

# -------------------------------------------------------------
# SERVER
# -------------------------------------------------------------
# Port the Express server listens on.
# Railway injects PORT automatically; override here for local dev.
PORT=3000

# -------------------------------------------------------------
# ENVIRONMENT
# -------------------------------------------------------------
# Set to "production" on Railway / CI. Controls SSL behaviour:
#   - production  → SSL enabled (rejectUnauthorized: false)
#   - development → SSL disabled (safe for local Postgres)
NODE_ENV=development
